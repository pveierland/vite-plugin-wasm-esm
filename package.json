{
	"name": "vite-plugin-wasm-esm",
	"version": "1.1.0-internal",
	"type": "module",
	"license": "MIT",
	"description": "Internal fork: wasm-pack ESM integration with SSR support, using the current wasm-bindgen init API.",
	"packageManager": "pnpm@10.4.1",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist/"
	],
	"scripts": {
		"dev": "tsup src/index.ts --format esm --dts --watch",
		"build": "tsup src/index.ts --format esm --dts",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"peerDependencies": {
		"vite": "5.x || 6.x || 7.x"
	},
	"devDependencies": {
		"@types/node": "^22.13.4",
		"prettier": "^3.5.1",
		"tsup": "^8.3.6",
		"typescript": "^5.7.3",
		"vite": "^7.2.0",
		"vitest": "^2.1.0"
	}
}
